        "800": { "value": "#0F2440", "type": "color", "description": "Primary Navy。ヘッダーCTA・電話ボタン・スタッツ帯・フッターCTA・カードアイコン背景の基準色" },
        "700": { "value": "#16324F", "type": "color", "description": "Navyのやや明るいトーン。カード見出しテキスト等" },
        "600": { "value": "#1C3A5E", "type": "color", "description": "Navyのアクセントトーン。バッジ枠線など" },
